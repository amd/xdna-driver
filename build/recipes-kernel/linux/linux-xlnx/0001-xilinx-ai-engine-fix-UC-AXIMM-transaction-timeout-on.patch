From 98e5bdf39d9f82d1a4b7f9f2befbfb1371ca3bd5 Mon Sep 17 00:00:00 2001
From: Saif <saifuddin.kaijar@amd.com>
Date: Tue, 12 May 2026 14:14:29 +0530
Subject: [PATCH] xilinx-ai-engine: fix UC AXIMM transaction timeout on
 reinitialization

During reinitialization, UC firmware continues running in infinite loop.
Must halt UC via column reset before polling for cleared transactions.

Reorder sequence: pause DMA, reset columns/shim, then poll.

Signed-off-by: Saif <saif@amd.com>
---
 drivers/misc/xilinx-ai-engine/ai-engine-reset.c | 14 +++++++++++---
 1 file changed, 11 insertions(+), 3 deletions(-)

diff --git a/drivers/misc/xilinx-ai-engine/ai-engine-reset.c b/drivers/misc/xilinx-ai-engine/ai-engine-reset.c
index 502787eb9397..0bf16bf99a95 100644
--- a/drivers/misc/xilinx-ai-engine/ai-engine-reset.c
+++ b/drivers/misc/xilinx-ai-engine/ai-engine-reset.c
@@ -839,6 +839,17 @@ int aie2ps_part_initialize(struct aie_partition *apart, struct aie_partition_ini
 	if (ret)
 		goto out;
 
+	opts = 0;
+	opts |= (args->init_opts & AIE_PART_INIT_OPT_COLUMN_RST);
+	opts |= (args->init_opts & AIE_PART_INIT_OPT_SHIM_RST);
+	/* push opts to pm and flush, these ops needs to complete before we perform next ones*/
+	ret = aie_part_pm_ops(apart, NULL, opts, apart->range, 1);
+	if (ret) {
+		dev_err(&apart->dev, "pm ops: 0x%x failed: %d", opts, ret);
+		goto out;
+	}
+
+        /* Poll for cleared outstanding transactions */
 	ret = aie_part_maskpoll_noc_outstanding_aximm_txn(apart);
 	if (ret)
 		goto out;
@@ -855,9 +866,6 @@ int aie2ps_part_initialize(struct aie_partition *apart, struct aie_partition_ini
 
 	/* First lets send non-data aie_op_type_len ops */
 	opts = 0;
-	/* This operation will do first 4 steps of sequence */
-	opts |= (args->init_opts & AIE_PART_INIT_OPT_COLUMN_RST);
-	opts |= (args->init_opts & AIE_PART_INIT_OPT_SHIM_RST);
 	opts |= (args->init_opts & AIE_PART_INIT_OPT_BLOCK_NOCAXIMMERR);
 	opts |= (args->init_opts & AIE_PART_INIT_OPT_ENB_COLCLK_BUFF);
 	/* push opts to pm and flush, these ops needs to complete before we perform next ones*/
-- 
