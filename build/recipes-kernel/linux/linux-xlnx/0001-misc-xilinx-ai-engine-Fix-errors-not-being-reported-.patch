From d01bd16697e20b8711a75b070cc46c9814034fb0 Mon Sep 17 00:00:00 2001
From: Gregory Williams <gregory.williams@amd.com>
Date: Tue, 21 Apr 2026 13:54:47 -0700
Subject: [PATCH] misc: xilinx-ai-engine: Fix errors not being reported for
 non-zero start column

The for loop calculation in aie2ps partition backtrack should use
apart->start.col + apart->size.col instead of just size. If for example
start column is 4 and size is 4, the for loop is never entered and
l1_backtrack is never called.

Signed-off-by: Gregory Williams <gregory.williams@amd.com>
---
 drivers/misc/xilinx-ai-engine/ai-engine-interrupt.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/misc/xilinx-ai-engine/ai-engine-interrupt.c b/drivers/misc/xilinx-ai-engine/ai-engine-interrupt.c
index 9d1f972852cc..08252202729d 100644
--- a/drivers/misc/xilinx-ai-engine/ai-engine-interrupt.c
+++ b/drivers/misc/xilinx-ai-engine/ai-engine-interrupt.c
@@ -986,7 +986,8 @@ static void aie2ps_partition_backtrack(struct aie_partition *apart)
 	}
 
 	_aie2ps_interrupt_user_event1(apart);
-	for (col = apart->range.start.col; col < apart->range.size.col; col++) {
+	for (col = apart->range.start.col;
+	     col < apart->range.start.col + apart->range.size.col; col++) {
 		struct aie_location loc = {.col = col, .row = 0};
 		u32 ttype, l2_mask;
 
-- 
2.34.1

