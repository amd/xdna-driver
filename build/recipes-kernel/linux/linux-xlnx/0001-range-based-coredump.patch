 .../misc/xilinx-ai-engine/ai-engine-part.c    | 335 +++++++++++++++---
 1 file changed, 290 insertions(+), 45 deletions(-)

diff --git a/drivers/misc/xilinx-ai-engine/ai-engine-part.c b/drivers/misc/xilinx-ai-engine/ai-engine-part.c
index 9db5a8cc37e4..9ac8357afe29 100644
--- a/drivers/misc/xilinx-ai-engine/ai-engine-part.c
+++ b/drivers/misc/xilinx-ai-engine/ai-engine-part.c
@@ -1949,7 +1949,7 @@ int aie_partition_coredump(struct device *dev, size_t len, void *data) {
 	struct aie_partition *apart;
 	struct aie_location loc;
 	u32 ttype;
-	int ret = 0;
+	int i, ret = 0;
 
 	if (!dev || !data)
 		return -EINVAL;
@@ -1982,62 +1982,307 @@ int aie_partition_coredump(struct device *dev, size_t len, void *data) {
 
 	for (loc.col = 0; loc.col < apart->range.size.col; loc.col++) {
 		for (loc.row = 0; loc.row < apart->range.size.row; loc.row++) {
-			size_t tile_base_offset = (loc.col * apart->range.size.row + loc.row) 
-						  * (1 << apart->adev->row_shift);
-
-			ttype = apart->adev->ops->get_tile_type(apart->adev, &loc);
-			if (ttype == AIE_TILE_TYPE_SHIMNOC) {
-				offset = 0;
-				dump_len = 1 << apart->adev->row_shift;
-				ret = aie_partition_read(dev, loc, offset, dump_len, 
-							(char*)data + tile_base_offset);
-				if (ret < 0) {
-					dev_err(dev, "failed to read shim tile at %d,%d", loc.col, loc.row);
-					return ret;
-				}
-			} else if (ttype == AIE_TILE_TYPE_TILE) {
-				/* Read first 64KB region */
-				offset = 0x0;
-				dump_len = KBYTES(64);
-				ret = aie_partition_read(dev, loc, offset, dump_len, 
-							(char*)data + tile_base_offset + offset);
-				if (ret < 0) {
-					dev_err(dev, "failed to read tile at %d,%d", loc.col, loc.row);
-					return ret;
-				}
+		size_t tile_base_offset = (loc.col * apart->range.size.row + loc.row)
+					  * (1 << apart->adev->row_shift);
+
+		/* Common structure for register range definitions */
+		struct aie_reg_range {
+			u32 offset;
+			u32 len;
+		};
 
-				/* Read remaining region */
-				offset = KBYTES(64);
-				dump_len = (1 << apart->adev->row_shift) - offset;
-				ret = aie_partition_read(dev, loc, offset, dump_len, 
-							(char*)data + tile_base_offset + offset);
+		ttype = apart->adev->ops->get_tile_type(apart->adev, &loc);
+
+		/* Initialize the tile region to zero first */
+		memset((char *)data + tile_base_offset, 0, 1 << apart->adev->row_shift);
+
+		if (ttype == AIE_TILE_TYPE_SHIMNOC) {
+			/* SHIM NOC tile register ranges */
+			static const struct aie_reg_range shim_noc_ranges[] = {
+				// Lock registers + Locks Event Selection 0x00000-0x00128
+				{0x00000, 0x128},
+				{0x00128, 0x04},
+				// Interrupt controller 2nd level 0x01000-0x01010
+				{0x01000, 0x10},
+				{0x01010, 0x04},
+				// Config register 0x02000
+				{0x02000, 0x04},
+				// Config registers 0x02100-0x02108
+				{0x02100, 0x08},
+				{0x02108, 0x04},
+				// Config register 0x02120
+				{0x02120, 0x04},
+				// Config register 0x03000
+				{0x03000, 0x04},
+				// DMA BD + Control/Status 0x09000-0x09348
