+				ret = aie_partition_read(dev, loc, offset, dump_len,
+							(char *)data + tile_base_offset + offset);
 				if (ret < 0) {
-					dev_err(dev, "failed to read memory tile at %d,%d", loc.col, loc.row);
+					dev_err(dev, "failed to read core tile range 0x%x at %d,%d",
+						offset, loc.col, loc.row);
 					return ret;
 				}
-
-				/* Read remaining region */
-				offset = KBYTES(512);
-				dump_len = (1 << apart->adev->row_shift) - offset;
-				ret = aie_partition_read(dev, loc, offset, dump_len, 
-							(char*)data + tile_base_offset + offset);
