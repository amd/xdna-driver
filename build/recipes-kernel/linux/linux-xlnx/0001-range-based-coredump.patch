+				// Memory Timer/Event 0x14000-0x14088
+				{0x14000, 0x88},
+				{0x14088, 0x04},
+				// Memory Timer/Event 0x140D0-0x14104
+				{0x140D0, 0x38},
+				// Event Status 0x14200-0x1420C
+				{0x14200, 0x10},
+				// Event 0x14400-0x14408
+				{0x14400, 0x08},
+				{0x14408, 0x04},
+				// Event Groups 0x14500-0x1451C
