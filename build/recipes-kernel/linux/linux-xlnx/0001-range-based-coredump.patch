+				{0x88000, 0x4000},
+				// MDM Debug 0xB0010-0xB0018
+				{0xB0010, 0x08},
+				{0xB0018, 0x04},
+				// MDM Debug 0xB5440
+				{0xB5440, 0x04},
+				// MDM Debug 0xB5480
+				{0xB5480, 0x04},
+				// MDM Debug 0xB54C0
+				{0xB54C0, 0x04},
+				// MDM Debug 0xB5580
+				{0xB5580, 0x04},
+				// MDM Debug 0xB55C0
+				{0xB55C0, 0x04},
+				// Core registers 0xC0000-0xC0008
+				{0xC0000, 0x08},
+				{0xC0008, 0x04},
+				// Core registers 0xC0020-0xC003C
+				{0xC0020, 0x20},
+				// Core registers 0xC0100-0xC0120
+				{0xC0100, 0x20},
+				{0xC0120, 0x04},
+				// Module Data Memory 0xD0000-0xD7FFC
+				{0xD0000, 0x8000}
+			};
+
+			/* Read SHIM NOC register ranges */
+			for (i = 0; i < ARRAY_SIZE(shim_noc_ranges); i++) {
+				offset = shim_noc_ranges[i].offset;
+				dump_len = shim_noc_ranges[i].len;
+				ret = aie_partition_read(dev, loc, offset, dump_len,
+							(char *)data + tile_base_offset + offset);
 				if (ret < 0) {
-					dev_err(dev, "failed to read tile at %d,%d", loc.col, loc.row);
+					dev_err(dev, "failed to read shim range 0x%x at %d,%d",
+						offset, loc.col, loc.row);
 					return ret;
 				}
-
-			} else if (ttype == AIE_TILE_TYPE_MEMORY) {
-				/* Read first 512KB */
-				offset = 0x0;
-				dump_len = KBYTES(512);
-				ret = aie_partition_read(dev, loc, offset, dump_len, 
-							(char*)data + tile_base_offset + offset);
+			}
+		} else if (ttype == AIE_TILE_TYPE_TILE) {
+			/* Core tile register ranges */
+			static const struct aie_reg_range core_tile_ranges[] = {
+				/* DataMemory 0x00000-0x0FFFC */
+				{0x00000, 0x10000},
+				/* Memory Performance counters 0x11000-0x1102C */
+				{0x11000, 0x30},
+				/* Memory Performance counters 0x11080-0x11084 */
+				{0x11080, 0x08},
+				/* ECC 0x12000 */
+				{0x12000, 0x04},
+				/* ECC 0x12110-0x12124 */
