+				{0x32DD0, 0x04},
+				// Core Timer/Event 0x34000-0x34088
+				{0x34000, 0x88},
+				{0x34088, 0x04},
+				// Core Timer/Event 0x340D0-0x340FC
+				{0x340D0, 0x30},
+				// Event Status 0x34200-0x3420C
