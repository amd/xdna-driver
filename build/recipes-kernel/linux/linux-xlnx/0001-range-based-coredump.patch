+				{0x34400, 0x08},
+				{0x34408, 0x04},
+				// Event Groups 0x34500-0x3452C
+				{0x34500, 0x30},
+				// Event register 0x34600
+				{0x34600, 0x04},
+				// Interrupt controller 1st level 0x35000-0x35050
+				{0x35000, 0x50},
+				{0x35050, 0x04},
+				// BISR 0x36000-0x3604C
+				{0x36000, 0x50},
+				// Stream Switch Master Config 0x3F000-0x3F058
+				{0x3F000, 0x58},
+				{0x3F058, 0x04},
