+				{0x36060, 0x10},
+				{0x36070, 0x04},
+				// Core Performance counters 0x37500-0x37508
+				{0x37500, 0x08},
+				{0x37508, 0x04},
+				// Core Performance counters 0x37520-0x3752C
+				{0x37520, 0x10},
+				// Core Performance counters 0x37580-0x3758C
+				{0x37580, 0x10},
+				// Core Control/Status/Debug 0x38000-0x38038
+				{0x38000, 0x38},
+				{0x38038, 0x04},
+				// Core Control/Status/Debug 0x38100-0x38120
+				{0x38100, 0x20},
+				{0x38120, 0x04},
+				// Stream Switch Master Config 0x3F000-0x3F058
+				{0x3F000, 0x58},
+				{0x3F058, 0x04},
+				// Stream Switch Slave Config 0x3F100-0x3F160
+				{0x3F100, 0x60},
+				{0x3F160, 0x04},
+				// Stream Switch Slave Slots 0x3F200-0x3F38C
+				{0x3F200, 0x190},
+				// Stream Switch Deterministic Merge 0x3F800-0x3F818
+				{0x3F800, 0x18},
+				{0x3F818, 0x04},
+				// Stream Switch Event/Status 0x3FF00-0x3FF38
+				{0x3FF00, 0x38},
+				{0x3FF38, 0x04},
+				// Module Clock/Reset/Tile Control 0x60000-0x60030
+				{0x60000, 0x30},
+				{0x60030, 0x04},
+				// Module Clock/Reset/Tile Control 0x60100-0x60104
+				{0x60100, 0x08}
+			};
+
+			/* Read Core tile register ranges */
+			for (i = 0; i < ARRAY_SIZE(core_tile_ranges); i++) {
