@@ -2237,7 +2237,7 @@ static ssize_t aie_get_tile_sysfs_bd_metadata(struct aie_partition *apart,
 
 			regoff = aie_cal_regoff(apart->adev, *loc,
 						base_bdoff + (i * 4U));
-			bd_data[i] = ioread32(apart->aperture->base + regoff);
+			bd_data[i] = aie_part_ioread32(apart, apart->aperture->base + regoff);
 		}
 
 		/* address and length */
