 				va = aperture->base +
 				     aie_cal_regoff(adev, loc,
 						    AIE_SHIMPL_CLKCNTR_REGOFF);
-				val = ioread32(va);
+				val = aie_part_ioread32(apart, va);
 
 				/*
 				 * check if the clock buffer and the next clock
@@ -1359,7 +1359,7 @@ static int aie_scan_part_clocks(struct aie_partition *apart)
 			va = aperture->base +
 			     aie_cal_regoff(adev, loc,
 					    AIE_TILE_CORE_CLKCNTR_REGOFF);
-			val = ioread32(va);
+			val = aie_part_ioread32(apart, va);
 
 			/*
 			 * If the next tile is gated, skip the rest of the
@@ -1423,7 +1423,7 @@ static int aie_set_col_clocks(struct aie_partition *apart,
 			va = aperture->base +
 			     aie_cal_regoff(adev, ploc,
 					    AIE_SHIMPL_CLKCNTR_REGOFF);
-			iowrite32(val, va);
+			aie_part_iowrite32(apart, val, va);
 		} else {
 			void __iomem *va;
 			u32 val = 0;
@@ -1438,7 +1438,7 @@ static int aie_set_col_clocks(struct aie_partition *apart,
 			va = aperture->base +
 			     aie_cal_regoff(adev, ploc,
 					    AIE_TILE_CORE_CLKCNTR_REGOFF);
-			iowrite32(val, va);
+			aie_part_iowrite32(apart, val, va);
 		}
 
 		/* If the tile clock is not on, jump to next column */
@@ -1515,13 +1515,13 @@ static u32 aie_get_core_status(struct aie_partition *apart,
 	u32 regoff, regvalue, eventval;
 
 	regoff = aie_cal_regoff(apart->adev, *loc, aie_core_sts.regoff);
-	regvalue = ioread32(apart->aperture->base + regoff);
+	regvalue = aie_part_ioread32(apart, apart->aperture->base + regoff);
 
 	/* Apply core done workaround */
 	if (!FIELD_GET(aie_core_done.mask, regvalue)) {
 		regoff = aie_cal_regoff(apart->adev, *loc,
 					aie_core_disable_event_sts.regoff);
-		eventval = ioread32(apart->aperture->base + regoff);
+		eventval = aie_part_ioread32(apart, apart->aperture->base + regoff);
 
 		if (FIELD_GET(aie_core_disable_event_sts.mask, eventval))
 			regvalue |= aie_core_done.mask;
@@ -1582,7 +1582,7 @@ static int aie_set_tile_isolation(struct aie_partition *apart,
 		va = aperture->base +
 		     aie_cal_regoff(adev, *loc, AIE_SHIMPL_TILECTRL_REGOFF);
 	}
-	iowrite32(val, va);
+	aie_part_iowrite32(apart, val, va);
 
 	return 0;
 }
@@ -1606,7 +1606,7 @@ static u32 aie_get_lock_status(struct aie_partition *apart,
 
 	regoff = aie_cal_regoff(apart->adev, *loc, stsoff);
 
-	return ioread32(apart->aperture->base + regoff);
+	return aie_part_ioread32(apart, apart->aperture->base + regoff);
 }
 
 /**
@@ -1770,7 +1770,7 @@ static u32 aie_get_dma_s2mm_status(struct aie_partition *apart,
 
 	regoff = aie_cal_regoff(apart->adev, *loc, stsoff);
 
-	return ioread32(apart->aperture->base + regoff);
+	return aie_part_ioread32(apart, apart->aperture->base + regoff);
 }
 
 /**
@@ -1792,7 +1792,7 @@ static u32 aie_get_dma_mm2s_status(struct aie_partition *apart,
 
 	regoff = aie_cal_regoff(apart->adev, *loc, stsoff);
 
-	return ioread32(apart->aperture->base + regoff);
+	return aie_part_ioread32(apart, apart->aperture->base + regoff);
 }
 
 /**
@@ -1941,7 +1941,7 @@ static u32 aie_get_fifo_status(struct aie_partition *apart,
 
 	regoff = aie_cal_regoff(apart->adev, *loc, fifo_off);
 
-	return ioread32(apart->aperture->base + regoff);
+	return aie_part_ioread32(apart, apart->aperture->base + regoff);
 }
 
