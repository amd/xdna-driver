ROOT := $(src)

ccflags-y += -I$(ROOT)/
# uAPI
ccflags-y += -I$(ROOT)/../../../include/uapi
# version.h
ccflags-y += -I$(ROOT)/../../../include
# Make every C file in this dir see config-kernel.h
ccflags-y += -include $(ROOT)/config_kernel.h

# All warning will report as error and debug build
ccflags-y += -g -Werror

ccflags-${UMQ_HELLO_TEST} += -DUMQ_HELLO_TEST

obj-m	+= amdxdna.o
# Only objects that have corresponding .c sources in this directory
amdxdna-y := \
	amdxdna_ctx.o \
	amdxdna_gem.o \
	amdxdna_mailbox.o \
	amdxdna_mailbox_helper.o \
	amdxdna_pci_drv.o \
	amdxdna_pm.o \
	amdxdna_sysfs.o \
	amdxdna_ubuf.o \

amdxdna-$(OFT_CONFIG_AMDXDNA_PCI) += \
	aie2_ctx.o \
	aie2_error.o \
	aie2_message.o \
	aie2_pci.o \
	aie2_pm.o \
	aie2_psp.o \
	aie2_smu.o \
	aie2_solver.o \
	npu1_regs.o \
	npu4_regs.o \
	npu5_regs.o \
	npu6_regs.o \
